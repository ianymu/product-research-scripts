    "sources": [
      "NIH NHLBI — How Much Sleep Is Enough",
      "AASM Consensus Statement (PMC4434546)",
      "CDC — About Sleep",
      "Mayo Clinic — Resting Heart Rate / Bradycardia / Tachycardia",
